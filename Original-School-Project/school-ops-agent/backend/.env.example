# Copy to backend/.env and fill in. NEVER commit the real .env.
# Secret rotation: rotate SECRET_KEY and provider keys via your secret manager;
# JWTs expire after ACCESS_TOKEN_TTL_MINUTES so rotation invalidates old tokens
# within that window. Invite tokens are single-use and short-lived.

ENVIRONMENT=local
DEBUG=true

# --- Database ---
# Default SQLite (zero setup). For Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/schoolops
DATABASE_URL=sqlite:///./school_ops.db

# --- Auth (CHANGE IN NON-LOCAL) ---
SECRET_KEY=dev-only-insecure-change-me
ACCESS_TOKEN_TTL_MINUTES=60
INVITE_TOKEN_TTL_HOURS=72

# --- LLM ---
# auto = live if a key is present, else deterministic mock (offline-safe)
LLM_MODE=auto
LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# --- Channels ---
CHANNEL_MODE=mock
# TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_WEBHOOK_SECRET=dev-webhook-secret

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Scheduler ---
SCHEDULER_TICK_SECONDS=30

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760
